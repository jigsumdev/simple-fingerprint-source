# API timeout for IP/geo providers and /api/geoip (ms)
# VITE_API_TIMEOUT=3000
#
# GeoLite2 MMDBs: place GeoLite2-City.mmdb and GeoLite2-ASN.mmdb under GeoIP/
# (used by npm run dev / vite preview via /api/geoip — not bundled into static build)

# Offline audio / parallel async bundle budget (ms)
# VITE_AUDIO_TIMEOUT_MS=8000

# WebRTC ICE gathering max wait (ms)
# VITE_WEBRTC_TIMEOUT_MS=5000

# Media + client hints budget (ms)
# VITE_SYNC_SIGNALS_TIMEOUT_MS=15000

# Never run WebRTC leak probe or high-entropy User-Agent Client Hints
# VITE_STRICT_SCAN=false

# Zustand devtools (defaults true in development)
# VITE_ENABLE_DEVTOOLS=true
